# Power BI MCP Server — environment variables
#
# Auth mode is chosen automatically:
#   - Set all three vars  → Service Principal (client credentials, no browser)
#   - Omit CLIENT_SECRET  → Interactive Device Code (sign in via browser on first use)

PBI_TENANT_ID=your-tenant-id-here
PBI_CLIENT_ID=your-client-id-here

# Optional — omit this line entirely to use interactive Device Code login instead
PBI_CLIENT_SECRET=your-client-secret-here
